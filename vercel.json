{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "Proses/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/Proses/(.*)\\.php", "dest": "/Proses/$1.php" },
    { "src": "/(.*)\\.php", "dest": "/$1.php" },
    { "src": "/", "dest": "/index.html" }
  ]
}